  "FirewallSettings": {
    "RateLimit": {
      "MaxRequestsPerMinute": 60,
      "BurstLimit": 10,
      "BurstWindowSeconds": 5,
      "BanDurationMinutes": 60,
      "SensitivePathLimits": {
        "/api/auth/login": 5,
        "/api/auth/register": 3
      }
    },
    "RequestValidation": {
      "MaxRequestSizeBytes": 10485760,
      "MaxHeaderCount": 50,
      "MaxHeaderSizeBytes": 8192,
      "AllowedMethods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "PATCH",
        "OPTIONS"
      ],
      "BlockedContentTypes": [
        "application/x-msdownload",
        "application/x-sh",
        "application/x-executable"
      ]
    },
    "Security": {
      "EnableSqlInjectionProtection": true,
      "EnableXssProtection": true,
      "EnablePathTraversalProtection": true,
      "EnableBotProtection": true,
      "EnableSecurityHeaders": true,
      "IpWhitelist": [],
      "IpBlacklist": []
    },
    "Monitoring": {
      "EnableMetrics": true,
      "LogBlockedRequests": true,
      "LogRateLimitViolations": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "wenu.Middleware.FirewallMiddleware": "Warning",
      "wenu.Services.StreamingHub": "Information"
    }
  },
  "Redis": {
    "ConnectionString": "redis:6379,abortConnect=false"
  },
  "MaintenanceJob": {
    "IntervalDays": 30
