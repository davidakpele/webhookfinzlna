{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=finzla_db;Username=postgres;Password=root"
  },
  "JwtSettings": {
    "SecretKey": "3hbXrhqhmvPD0bVq9Ce4hxTqALG701J7jRXyfKjqtzDPIlbdJ8YMIfZtHmPlC6Js9JVpELE2tj4KGP1VoCMA4Ya58WGF3Hs1",
    "Issuer": "Finzla",
    "Audience": "Finzla Technologies Nigeria Limited",
    "ExpiryInMinutes": "30"
  }, 
  "FirewallSettings": {
    "RateLimit": {
      "MaxRequestsPerMinute": 60,
      "BurstLimit": 10,
      "BurstWindowSeconds": 5,
      "BanDurationMinutes": 60,
      "EnableBurstBlocking": true,
      "EnableBan": true,
      "EnableRateLimitHeaders": true,
      "EnableDistributedRateLimiting": true,
      "EnableClientFingerprinting": true,
      "ClientFingerprintHeaders": [
        "User-Agent",
        "Accept-Language",
        "X-Forwarded-For"
      ],
      "EnableAdaptiveRateLimiting": true,
      "AdaptiveRateLimitThreshold": 0.8,
      "AdaptiveRateLimitWindowSeconds": 300,
      "AdaptiveRateLimitIncreaseFactor": 2.0,
      "AdaptiveRateLimitDecreaseFactor": 0.5,
      "AdaptiveRateLimitCooldownSeconds": 600,
      "EnableGeoIpRateLimiting": true,
      "GeoIpRateLimitRules": [
        {
          "Country": "CN",
          "MaxRequestsPerMinute": 20,
          "BanDurationMinutes": 120
        },
        {
          "Country": "RU",
          "MaxRequestsPerMinute": 30,
          "BanDurationMinutes": 90
        }
      ],
      "EnableUserAgentRateLimiting": true,
      "UserAgentRateLimitRules": [
        {
          "UserAgentPattern": "curl/*",
          "MaxRequestsPerMinute": 10,
          "BanDurationMinutes": 60
        },
        {
          "UserAgentPattern": "*bot*",
          "MaxRequestsPerMinute": 15,
          "BanDurationMinutes": 90
        }
      ],
      "EnableIpReputationRateLimiting": true,
      "IpReputationRateLimitRules": [
        {
          "ReputationScoreThreshold": 0.5,
          "MaxRequestsPerMinute": 10,
          "BanDurationMinutes": 60
        }
      ],
      "EnableDynamicRateLimiting": true,
      "DynamicRateLimitRules": [
        {
          "Metric": "requests_per_minute",
          "Threshold": 100,
          "MaxRequestsPerMinute": 20,
          "BanDurationMinutes": 60
        }
      ],
      "EnableExponentialBackoff": true,
      "ExponentialBackoffBaseSeconds": 30,
      "ExponentialBackoffMaxSeconds": 3600,
      "EnableRateLimitResponseHeaders": true,
      "RateLimitResponseHeaders": {
        "Retry-After": "Retry-After",
        "X-RateLimit-Limit": "X-RateLimit-Limit",
        "X-RateLimit-Remaining": "X-RateLimit-Remaining",
        "X-RateLimit-Reset": "X-RateLimit-Reset"
      },
      "EnableCustomRateLimitResponses": true,
      "CustomRateLimitResponseStatusCode": 429,
      "CustomRateLimitResponseBody": "{\"error\":\"Too many requests. Please try again later.\"}",
      "CustomRateLimitResponseContentType": "application/json",
      "EnableRateLimitLogging": true,
      "RateLimitLogLevel": "Warning",
      "RateLimitLogTemplate": "Rate limit exceeded: {ClientIp} - {RequestPath} - {Reason}",
      "EnableRateLimitMetrics": true,
      "RateLimitMetricsNamespace": "FirewallMiddleware",
      "RateLimitMetricsLabels": [
        "ClientIp",
        "RequestPath",
        "Reason"
      ],
      "EnableRateLimitCounters": true,
      "RateLimitCounterLabels": [
        "ClientIp",
        "RequestPath",
        "Reason"
      ],
      "EnableRateLimitEvents": true,
      "RateLimitEventName": "RateLimitExceeded",
      "RateLimitEventProperties": [
        "ClientIp",
        "RequestPath",
        "Reason"
      ],
      "EnableRateLimitNotifications": true
      
    },
    "RequestValidation": {
      "MaxRequestSizeBytes": 10485760,
      "MaxHeaderCount": 50,
      "MaxHeaderSizeBytes": 8192,
      "AllowedMethods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "PATCH",
        "OPTIONS"
      ],
      "BlockedContentTypes": [
        "application/x-msdownload",
        "application/x-sh",
        "application/x-executable"
      ]
    },
    "Security": {
      "EnableSqlInjectionProtection": true,
      "EnableXssProtection": true,
      "EnablePathTraversalProtection": true,
      "EnableBotProtection": true,
      "EnableSecurityHeaders": true,
      "IpWhitelist": [],
      "IpBlacklist": []
    },
    "Monitoring": {
      "EnableMetrics": true,
      "LogBlockedRequests": true,
      "LogRateLimitViolations": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "wenu.Middleware.FirewallMiddleware": "Warning",
      "wenu.Services.StreamingHub": "Information"
    }
  },
  "Redis": {
    "ConnectionString": "redis:6379,abortConnect=false"
  },
  "MaintenanceJob": {
    "IntervalDays": 30
  },
  "AllowedHosts": "*"
}